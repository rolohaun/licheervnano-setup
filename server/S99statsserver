#!/bin/sh
# Init script to auto-start the stats web server at boot.
# Install: cp S99statsserver /etc/init.d/ && chmod +x /etc/init.d/S99statsserver

SCRIPT="/opt/statsserver/server.py"
PIDFILE="/var/run/statsserver.pid"

start() {
    echo "Starting stats server..."
    python3 "$SCRIPT" &
    echo $! > "$PIDFILE"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        kill "$(cat $PIDFILE)" 2>/dev/null
        rm -f "$PIDFILE"
        echo "Stats server stopped."
    fi
}

case "$1" in
    start) start ;;
    stop)  stop  ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
